<Window x:Class="PokerLogViewer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PokerLogViewer.Converters"
        xmlns:viewmodels="clr-namespace:PokerLogViewer.ViewModels"
        Title="Poker Log Viewer" Height="650" Width="1050"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <viewmodels:MainViewModel/>
    </Window.DataContext>
    
    <Window.Resources>
        <ResourceDictionary>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:BoolInverseConverter x:Key="BoolInverseConverter"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:ZeroToVisibleConverter x:Key="ZeroToVisibleConverter"/>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <Border Grid.Row="0" Background="#F0F0F0" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Папка:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                <TextBox Grid.Column="1" Text="{Binding SelectedDirectory, UpdateSourceTrigger=PropertyChanged}" 
                         VerticalAlignment="Center" IsReadOnly="True" Background="White"/>
                <Button Grid.Column="2" Content="Обзор..." Command="{Binding BrowseDirectoryCommand}" 
                        Margin="10,0,10,0" Padding="10,5"
                        IsEnabled="{Binding IsScanning, Converter={StaticResource BoolInverseConverter}}"/>
                <Button Grid.Column="3" Content="▶ Начать сканирование" Command="{Binding StartScanCommand}" 
                        Margin="0,0,10,0" Padding="10,5" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                <Button Grid.Column="4" Content="⏹ Остановить" Command="{Binding StopScanCommand}" 
                        Padding="10,5" Background="#F44336" Foreground="White" FontWeight="Bold"/>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель - Столы -->
            <Border Grid.Column="0" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#2196F3" Padding="10" CornerRadius="5,5,0,0">
                        <TextBlock Text="Столы" Foreground="White" FontWeight="Bold" FontSize="14"/>
                    </Border>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Tables}" SelectedItem="{Binding SelectedTable}" 
                             Margin="5" BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                    <TextBlock Grid.Row="1" Text="Нет данных" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               Foreground="#999" FontSize="13"
                               Visibility="{Binding Tables.Count, Converter={StaticResource ZeroToVisibleConverter}}"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- Средняя панель - Раздачи -->
            <Border Grid.Column="2" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FF9800" Padding="10" CornerRadius="5,5,0,0">
                        <TextBlock Text="Раздачи" Foreground="White" FontWeight="Bold" FontSize="14"/>
                    </Border>
                    <ListBox Grid.Row="1" ItemsSource="{Binding HandIds}" SelectedItem="{Binding SelectedHandId}" 
                             Margin="5" BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StringFormat=Hand \#{0}}" FontSize="13"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Grid.Row="1" Text="Выберите стол" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               Foreground="#999" FontSize="13"
                               Visibility="{Binding HandIds.Count, Converter={StaticResource ZeroToVisibleConverter}}"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- Правая панель - Детали (ИСПРАВЛЕНО) -->
            <Border Grid.Column="4" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#9C27B0" Padding="10" CornerRadius="5,5,0,0">
                        <TextBlock Text="Детали раздачи" Foreground="White" FontWeight="Bold" FontSize="14"/>
                    </Border>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid Margin="15">
                            <!-- Детали (показываются когда есть SelectedHand) -->
                            <StackPanel Visibility="{Binding SelectedHand, Converter={StaticResource NullToVisibilityConverter}}">
                                
                                <!-- Информация о раздаче -->
                                <Border Background="#F5F5F5" Padding="15" Margin="0,0,0,15" CornerRadius="5">
                                    <StackPanel>
                                        <TextBlock Text="ИНФОРМАЦИЯ" FontWeight="Bold" Margin="0,0,0,12" 
                                                   FontSize="11" Foreground="#666"/>
                                        
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                                      Text="Hand ID:" FontWeight="Bold" 
                                                      Margin="0,0,10,10" FontSize="13"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                                      Text="{Binding SelectedHand.HandID}" 
                                                      Margin="0,0,0,10" FontSize="13"/>
                                            
                                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                                      Text="Стол:" FontWeight="Bold" 
                                                      Margin="0,0,10,10" FontSize="13"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" 
                                                      Text="{Binding SelectedHand.TableName}" 
                                                      Margin="0,0,0,10" FontSize="13"/>
                                            
                                            <TextBlock Grid.Row="2" Grid.Column="0" 
                                                      Text="Выигрыш:" FontWeight="Bold" 
                                                      Margin="0,0,10,0" FontSize="13"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" 
                                                      Text="{Binding SelectedHand.WinAmount}" 
                                                      FontWeight="Bold" Foreground="#4CAF50" FontSize="14"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Игроки -->
                                <Border Background="#F5F5F5" Padding="15" Margin="0,0,0,15" CornerRadius="5">
                                    <StackPanel>
                                        <TextBlock Text="ВСЕ ИГРОКИ" FontWeight="Bold" Margin="0,0,0,12" 
                                                   FontSize="11" Foreground="#666"/>
                                        
                                        <ItemsControl ItemsSource="{Binding SelectedHand.Players}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="White" Padding="10,8" Margin="0,0,0,5" 
                                                            CornerRadius="3" BorderBrush="#E0E0E0" BorderThickness="1">
                                                        <TextBlock Text="{Binding}" FontSize="13"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Победители -->
                                <Border Background="#F5F5F5" Padding="15" CornerRadius="5">
                                    <StackPanel>
                                        <TextBlock Text="ПОБЕДИТЕЛИ" FontWeight="Bold" Margin="0,0,0,12" 
                                                   FontSize="11" Foreground="#666"/>
                                        
                                        <ItemsControl ItemsSource="{Binding SelectedHand.Winners}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FFF8E1" Padding="10,8" Margin="0,0,0,5" 
                                                            CornerRadius="3" BorderBrush="#FFC107" BorderThickness="1">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="🏆 " FontSize="14" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding}" FontWeight="Bold" FontSize="13" 
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            
                            <!-- Placeholder -->
                            <TextBlock Text="Выберите раздачу для просмотра деталей" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                                       Foreground="#999" FontSize="14" TextWrapping="Wrap" TextAlignment="Center"
                                       Visibility="{Binding SelectedHand, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Статусная строка -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="10" Margin="0,10,0,0" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Статус:" FontWeight="Bold" Margin="0,0,10,0" FontSize="13"/>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" TextWrapping="NoWrap" 
                           TextTrimming="CharacterEllipsis" FontSize="13" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="2" Width="150" Height="20" IsIndeterminate="{Binding IsScanning}" 
                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
